        //        return StatusCode(500, errorResponse);
        //    }
        //}
        [HttpPut("{id:int}")]
        public async Task<ActionResult<ApiResponse<FoodDTO>>> UpdateVilla(int id, FoodItemUpdateDTO foodDTO)
        {
            try
            {
                if (foodDTO == null)
                {
                    return BadRequest(ApiResponse<object>.BadRequest("FoodItem datas are required"));

                }
                if (id != foodDTO.FoodItemId)
                {
                    return BadRequest(ApiResponse<object>.BadRequest("FoodItem id in URL does not similar to the villa id in request body"));
                }

                var existingFoodItem = await _context.FoodItems.FirstOrDefaultAsync(u => u.FoodItemId == id);
                if (existingFoodItem == null)
                {
                    return NotFound(ApiResponse<Object>.Notfound($"FoodItem with id {id} was not found"));
                }

                var duplicateVilla = await _context.FoodItems.FirstOrDefaultAsync(u => u.FoodItemName.ToLower() == foodDTO.FoodItemName.ToLower() && u.FoodItemId != id);
                if (duplicateVilla != null)
                {
                    return Conflict(ApiResponse<object>.Conflict($"A FoodItem with the name '{foodDTO.FoodItemName}' is alreay exists."));

                }

                _mapper.Map(foodDTO, existingFoodItem);
                await _context.SaveChangesAsync();
                var response = ApiResponse<FoodDTO>.Ok(_mapper.Map<FoodDTO>(foodDTO), "FoodItem updated successfully");
                return Ok(foodDTO);

            }
            catch (Exception ex)
            {
                return StatusCode(StatusCodes.Status500InternalServerError,
                    $"An Error occured while updating villa with ID {ex.Message} ");
            }
        }
    }

    }
