@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true"/>

</head>
<body class="body">
    <div class="dashboard-container">
        <h1>Admin Dashboard</h1>
        <div class="cards">
            <div class="card">
                <h3>Manage Food</h3>
                <p>Add, update or delete food items.</p>
                <a asp-controller="Admin" asp-action="MenuManage">Open</a>
            </div>

            <div class="card">
                <h3> Manage Categories</h3>
                <p>Organize food categories easily.</p>
                <a asp-controller="Admin" asp-action="CategoryManage">Open</a>
            </div>

            <div class="card">
                <h3> Manage Orders</h3>
                <p>View and update customer orders.</p>
                <a asp-controller="Admin" asp-action="OrderManage">Open</a>
            </div>

            <div class="card logout">
                <h3> Logout</h3>
                <p>Exit admin panel securely.</p>
                <a asp-controller="Auth" asp-action="Logout">Logout</a>
            </div>

        </div>
    </div>

</body>
</html>
